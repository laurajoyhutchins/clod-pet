{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "jest"],
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["main.ts", "src/**/*.ts"],
  "exclude": ["src/**/__tests__/**", "src/pet-renderer.ts", "node_modules"]
}
