{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "jest"],
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["main.ts", "src/**/*.ts"],
  "exclude": [
    "src/**/__tests__/**",
    "src/pet-renderer.ts",
    "src/editor/EditorApp.ts",
    "src/editor/main.ts",
    "src/editor/ipc.ts",
    "src/editor/theme.ts",
    "src/editor/sprite.ts",
    "src/editor/globals.d.ts",
    "node_modules"
  ]
}
