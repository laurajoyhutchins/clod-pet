{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["src/renderer/**/*.ts", "src/globals.d.ts"]
}
