{
  "name": "clod-pet",
  "version": "0.1.0",
  "description": "Desktop pet app",
  "main": "dist/src/main/main.js",
  "scripts": {
    "build:ts": "node scripts/build.js",
    "start": "npm run build:ts && node scripts/start-electron.js",
    "dev": "npm run build:ts && cross-env NODE_ENV=development node scripts/start-electron.js",
    "test": "npm run build:ts && jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest tests/e2e --runInBand --forceExit --testPathIgnorePatterns=/node_modules/"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^41.4.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ],
    "coveragePathIgnorePatterns": [
      "node_modules",
      "src/preload/preload.ts",
      "src/renderer/pet-renderer.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "ajv": "^8.20.0",
    "elkjs": "^0.11.1",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
