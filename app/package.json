{
  "name": "clod-pet",
  "version": "0.1.0",
  "description": "Desktop pet app",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "node scripts/build.js",
    "start": "npm run build:ts && electron --no-sandbox .",
    "dev": "npm run build:ts && cross-env NODE_ENV=development electron --no-sandbox .",
    "test": "npm run build:ts && jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest e2e --runInBand --forceExit --testPathIgnorePatterns=/node_modules/"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "cross-env": "^7.0.3",
    "electron": "^41.4.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ],
    "coveragePathIgnorePatterns": [
      "node_modules",
      "src/preload.js",
      "src/pet-renderer.js"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  }
}
